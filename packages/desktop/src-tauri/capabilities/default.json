{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "core:window:allow-start-dragging",
    "core:event:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "soffice",
          "cmd": "soffice",
          "args": true
        },
        {
          "name": "ffmpeg",
          "cmd": "ffmpeg",
          "args": true
        },
        {
          "name": "yt-dlp",
          "cmd": "yt-dlp",
          "args": true
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true
        }
      ]
    }
  ]
}
