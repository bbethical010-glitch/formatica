{
  "productName": "Formatica",
  "version": "1.0.0",
  "identifier": "com.formatica.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1425",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Formatica",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "publisher": "Formatica",
    "copyright": "© 2026 Formatica",
    "shortDescription": "Convert, download, and extract — privately.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
